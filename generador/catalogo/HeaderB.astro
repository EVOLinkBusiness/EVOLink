---
// HeaderB — logo centrado sobre una fila de navegacion centrada.
interface NavItem { label: string; ruta: string; }
interface Props {
  nav: NavItem[];
  cta?: { label: string; ruta: string };
  nombre_negocio?: string;
}
const { nav, cta, nombre_negocio = "" } = Astro.props;
---

<header class="border-b border-borde bg-fondo">
  <div class="contenedor flex flex-col items-center gap-3 py-4">
    <a href="/" class="font-titulares text-xl font-bold text-texto">{nombre_negocio}</a>
    <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
      <nav aria-label="Principal" class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
        {nav.map((i) => <a class="text-sm text-texto-suave hover:text-texto" href={i.ruta}>{i.label}</a>)}
      </nav>
      {cta && <a class="btn btn--primary text-sm" href={cta.ruta}>{cta.label}</a>}
    </div>
  </div>
</header>
