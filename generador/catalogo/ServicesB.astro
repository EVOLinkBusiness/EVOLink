---
// ServicesB — lista numerada con divisores (alternativa a la rejilla de tarjetas).
interface ServiceItem { icono?: string; titulo: string; texto: string; }
interface Props { titulo: string; items: ServiceItem[]; }
const { titulo, items } = Astro.props;
---

<section class="seccion" id="servicios">
  <div class="contenedor">
    <h2 class="titulo-seccion">{titulo}</h2>
    <div class="mt-10 divide-y divide-borde">
      {
        items.map((s, i) => (
          <div class="grid gap-2 py-6 md:grid-cols-[auto_1fr] md:gap-8">
            <span class="font-titulares text-2xl text-primario">{String(i + 1).padStart(2, "0")}</span>
            <div>
              <h3 class="text-xl font-semibold">{s.titulo}</h3>
              <p class="mt-1 text-texto-suave">{s.texto}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
