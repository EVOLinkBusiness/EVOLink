---
// HeroA — texto a la izquierda, imagen a la derecha. CTA primario (+ secundario opc).
interface Imagen { src: string; alt: string; }
interface Props {
  titulo: string;
  subtitulo: string;
  cta_label: string;
  cta_ruta: string;
  imagen?: Imagen;
  cta_secundario?: { label: string; ruta: string };
}
const { titulo, subtitulo, cta_label, cta_ruta, imagen, cta_secundario } = Astro.props;
---

<section class="seccion">
  <div class="contenedor grid items-center gap-10 md:grid-cols-2">
    <div>
      <h1 class="text-4xl font-bold md:text-5xl lg:text-6xl">{titulo}</h1>
      <p class="mt-5 max-w-prose text-lg text-texto-suave">{subtitulo}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="btn btn--primary" href={cta_ruta}>{cta_label}</a>
        {cta_secundario && <a class="btn btn--ghost" href={cta_secundario.ruta}>{cta_secundario.label}</a>}
      </div>
    </div>
    {
      imagen && (
        <img
          class="aspect-[4/3] w-full rounded-2xl object-cover"
          src={imagen.src}
          alt={imagen.alt}
          width="800"
          height="600"
          loading="eager"
        />
      )
    }
  </div>
</section>
