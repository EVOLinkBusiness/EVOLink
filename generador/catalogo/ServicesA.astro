---
// ServicesA — rejilla de 3 tarjetas de servicio.
interface ServiceItem { icono?: string; titulo: string; texto: string; }
interface Props { titulo: string; items: ServiceItem[]; }
const { titulo, items } = Astro.props;
---

<section class="seccion bg-superficie" id="servicios">
  <div class="contenedor">
    <h2 class="titulo-seccion">{titulo}</h2>
    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        items.map((s) => (
          <article class="rounded-xl border border-borde bg-fondo p-6">
            <h3 class="text-xl font-semibold">{s.titulo}</h3>
            <p class="mt-2 text-texto-suave">{s.texto}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
